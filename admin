<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Tea Club Admin Panel</title>
    <style>
        body { font-family: sans-serif; background: #2c3e50; color: white; display: flex; justify-content: center; padding-top: 50px; }
        .admin-card { background: white; color: #333; padding: 30px; border-radius: 12px; width: 400px; box-shadow: 0 10px 25px rgba(0,0,0,0.3); }
        .hidden { display: none; }
        input { padding: 12px; border: 1px solid #ddd; border-radius: 5px; margin-bottom: 15px; width: 100%; box-sizing: border-box; }
        .btn { padding: 12px; color: white; border: none; border-radius: 5px; cursor: pointer; width: 100%; font-weight: bold; margin-bottom: 10px; }
        .btn-update { background: #1a237e; }
        .btn-expense { background: #c0392b; }
        .btn-verify { background: #27ae60; }
        .tool-section { border-bottom: 1px solid #eee; margin-bottom: 20px; padding-bottom: 10px; }
    </style>
</head>
<body>

<div class="admin-card" id="loginArea">
    <h2 style="text-align:center">Admin Security</h2>
    <input type="password" id="adminPass" placeholder="Enter Admin Password">
    <button class="btn btn-update" onclick="checkPass()">Login</button>
</div>

<div class="admin-card hidden" id="adminDashboard">
    <h2 style="color:#1a237e">Admin Dashboard</h2>
    
    <div class="tool-section">
        <label><b>1. Set Subscription Cost</b></label>
        <input type="number" id="costInput" placeholder="e.g. 250">
        <button class="btn btn-update" onclick="updateData('cost')">Update Monthly Cost</button>
    </div>

    <div class="tool-section">
        <label><b>2. Deduct Expense</b></label>
        <input type="number" id="expenseInput" placeholder="Amount">
        <button class="btn btn-expense" onclick="updateData('expense')">Subtract from Funds</button>
    </div>

    <div class="tool-section">
        <label><b>3. Authorize Payment</b></label>
        <input type="text" id="verifyEmpId" placeholder="Enter Employee ID">
        <button class="btn btn-verify" onclick="updateData('verify')">Mark as PAID</button>
    </div>

    <button onclick="location.href='index.html'" style="background:none; border:none; color:#999; cursor:pointer; width:100%;">← Exit Admin</button>
</div>

<script>
    const scriptURL = 'https://script.google.com/macros/s/AKfycbwkuVfwWY-vLKex498qU3DgSEj7CBqzpKsAKscYAnBlFcc31mxT2mR9lSr_srpghgw8/exec';

    function checkPass() {
        if(document.getElementById('adminPass').value === "HRMS2026") {
            document.getElementById('loginArea').classList.add('hidden');
            document.getElementById('adminDashboard').classList.remove('hidden');
        } else {
            alert("Incorrect Password!");
        }
    }

    function updateData(actionType) {
        let val = "";
        if(actionType === 'cost') val = document.getElementById('costInput').value;
        if(actionType === 'expense') val = document.getElementById('expenseInput').value;
        if(actionType === 'verify') val = document.getElementById('verifyEmpId').value;

        if(!val) return alert("Please enter a value");

        const formData = new FormData();
        formData.append('action', actionType);
        formData.append('value', val);

        fetch(scriptURL, { method: 'POST', body: formData })
            .then(() => {
                alert("Data updated successfully in Google Sheets!");
                document.querySelectorAll('input[type="number"], input[type="text"]').forEach(i => i.value = "");
            })
            .catch(err => alert("Error: " + err));
    }
</script>
</body>
</html>
